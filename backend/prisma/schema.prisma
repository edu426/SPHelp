generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Professor {
  id      String   @id @default(cuid())
  clerkId String   @unique
  alunos  Alunos[]
}

model Alunos {
  id           String       @id @default(cuid())
  nome         String /// @encrypted
  turma        String
  dataNasc     DateTime     @default(now())
  diretorTurma String       @default("N/A") /// @encrypted
  professorId  String
  notas        String       @default("") /// @encrypted
  estrategias  String       @default("") /// @encrypted
  foto         String?
  updatedAt    DateTime     @updatedAt
  presenca     Presenca[]
  professor    Professor    @relation(fields: [professorId], references: [id])
  MSAI         MSAI[]
  Terapias     Terapias[]
  Encaregado   Encaregado[]
  Adaptacoes   Adaptacoes[]
}

model Encaregado {
  id       String @id @default(cuid())
  nome     String @default("") /// @encrypted
  tipo     String @default("") /// @encrypted
  email    String @default("") /// @encrypted
  telefone String @default("") /// @encrypted
  alunoId  String
  aluno    Alunos @relation(fields: [alunoId], references: [id], onDelete: Cascade)
}

model Atividades {
  id         String    @id @default(cuid())
  resumo     String /// @encrypted
  concluida  Boolean
  presencaId String?
  presenca   Presenca? @relation(fields: [presencaId], references: [id], onDelete: Cascade)
}

model MSAI {
  id      String @id @default(cuid())
  alunoId String
  msai    String @default("000000000000000") @db.Bit(15)
  aluno   Alunos @relation(fields: [alunoId], references: [id], onDelete: Cascade)
}

model Adaptacoes {
  id           String @id @default(cuid())
  alunoId      String
  adaptacao    String @default("00000000000") @db.Bit(11)
  outros       String @default("N/A") /// @encrypted
  observacoes  String @default("N/A") /// @encrypted
  aluno        Alunos @relation(fields: [alunoId], references: [id], onDelete: Cascade)
}

model Presenca {
  id           String       @id @default(cuid())
  alunoId      String
  data         DateTime     @default(now())
  sumario      String       @default("N/A") /// @encrypted
  presente     Boolean
  justifica    Boolean
  justificacao String? /// @encrypted
  aluno        Alunos       @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  atividades   Atividades[]
}

model Terapias {
  id                 String  @id @default(cuid())
  alunoId            String  @unique
  fisioterapia       Boolean @default(false)
  terapiaFala        Boolean @default(false)
  terapiaOcupacional Boolean @default(false)
  psicologia         Boolean @default(false)
  outros             Boolean @default(false)
  outrosDescricao    String? /// @encrypted
  notasTerapia       String? /// @encrypted
  aluno              Alunos  @relation(fields: [alunoId], references: [id], onDelete: Cascade)
}

//professorId deve ser irrelevante (substituido pela string diretorTurma)
