generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url  	    = env("DATABASE_URL")
}

model Professor{
  id        String   @id @default(cuid())
  clerkId   String   @unique
  alunos    Alunos[]
}

model Alunos{
  id        String   @id @default(cuid())
  nome      String
  turma     String
  professorId String
  professor   Professor @relation(fields: [professorId], references: [id])

}