generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Professor {
  id      String   @id @default(cuid())
  clerkId String   @unique
  alunos  Alunos[]
}

model Alunos {
  id           String     @id @default(cuid())
  nome         String     /// @encrypted
  turma        String
  dataNasc     DateTime   @default(now())
  diretorTurma String     @default("N/A")
  professorId  String
  notas        String     @default("") /// @encrypted
  foto         String?
  updatedAt    DateTime   @updatedAt
  presenca     Presenca[]
  professor    Professor  @relation(fields: [professorId], references: [id])

  MSAI MSAI[]
}
model Atividades{
  id          String   @id @default(cuid())
  resumo      String    /// @encrypted
  concluida   Boolean  
  presencaId  String?
  presenca    Presenca? @relation(fields: [presencaId], references: [id], onDelete: Cascade)
}

model MSAI {
  id      String @id @default(cuid())
  alunoId String
  msai    String @default("000000000000000") @db.Bit(15)
  aluno   Alunos @relation(fields: [alunoId], references: [id])
}

model Presenca { //vai deixar de ser so para presenças e vai passar a ser para aulas/apoio
  id        String   @id @default(cuid())
  alunoId   String
  data      DateTime @default(now())
  sumario   String   @default("N/A") /// @encrypted
  presente  Boolean
  justifica Boolean
  justificacao String?   /// @encrypted
  aluno     Alunos   @relation(fields: [alunoId], references: [id])
  atividades Atividades[]
}

//professorId deve ser irrelevante (substituido pela string diretorTurma)
